# Google OAuth (create at console.cloud.google.com > APIs & Services > Credentials)
# Redirect URI: https://people.4dsmarketing.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://people.4dsmarketing.com

# Database (Vercel Postgres / Neon)
DATABASE_URL=
DIRECT_URL=

# Vercel Blob (for document uploads)
BLOB_READ_WRITE_TOKEN=

# Slack Integration (for HR ticket notifications)
# Create a Slack App at api.slack.com/apps, add chat:write scope, install to workspace
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
